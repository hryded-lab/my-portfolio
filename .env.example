# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real keys.

# Groq — powers the AI Assistant window
# Get a key: https://console.groq.com/keys
GROQ_API_KEY=

# Discord webhook — receives contact form submissions
# Discord channel → Edit channel → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_WEBHOOK_URL=

# Resume URL — public link to your hosted resume PDF (Google Drive / Dropbox / etc.)
# Falls back to /resume.pdf locally if unset (file must exist in /public for local dev).
NEXT_PUBLIC_RESUME_URL=

# EmailJS — used by the Contact window's client-side fallback (optional)
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
